# Cluckin' Chaos — public site env (Vite)
# Copy to .env.local for local dev (required — without these the live board stays offline).
# On Vercel: Project → Settings → Environment Variables (Production + Preview), then Redeploy.
#
# IMPORTANT: Use the SAME Supabase project as TruckDash (published_trucks table).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Must match truck_id in TruckDash Settings when publishing
VITE_TRUCK_ID=cluckin-chaos
