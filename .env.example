# Cluckin' Chaos — public site env (Vite)
# Copy to .env.local for local dev. On Vercel: set env vars then redeploy.
#
# Use the SAME Supabase project as TruckDash.
# Run supabase/storage_buckets.sql in Supabase SQL Editor first.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Must match Truck ID in TruckDash Settings when publishing
VITE_TRUCK_ID=cluckin-chaos